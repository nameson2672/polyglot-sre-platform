# Shared
APP_ENV=dev
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# orders-api
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=orders;Username=orders;Password=orders_dev
