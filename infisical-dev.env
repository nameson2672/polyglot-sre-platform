# =============================================================================
#  Infisical import file  —  project: polyglot-sre-platform   env: dev   path: /
# =============================================================================
#  THIS FILE IS GITIGNORED (infisical-*.env). It holds REAL secret values.
#  Do NOT commit it, do NOT paste it in chat/tickets.
#
#  HOW TO USE — this is NOT read by your apps in the cluster. In Hetzner the
#  apps read k8s Secrets that External Secrets Operator builds FROM Infisical.
#  So you load these values INTO Infisical:
#     Infisical UI → project polyglot-sre-platform → env "Development" (dev)
#     → Secrets → "..." menu → Import .env → upload this file.
#  (Or CLI:  infisical secrets set --env=dev --projectId=<id> $(cat infisical-dev.env | grep -v '^#'))
#
#  The values below are STRONG RANDOM defaults I generated for you.
#  ⚠️  CHANGE every value marked "CHANGE ME" before relying on this.
#  ⚠️  Three pairs MUST stay equal to each other (noted inline) — if you
#      regenerate one, regenerate its partner too.
# =============================================================================


# ── checkout-bff  → Secret checkout-bff-secrets (ns dev) ─────────────────────
# Signs/verifies JWTs. Safe random; rotate whenever you like.
CHECKOUT_BFF_JWT_SECRET=Dk23XH0Rg2hJblVP0V8vwGVoue53wIGlNFtli51pFSetsgTN0VI4fb7MoPnjNdF4

# Shared API key checkout-bff uses to call orders-api.
# 🔗 MUST EQUAL  ORDERS_API_ORDERS_API_KEY  below.
CHECKOUT_BFF_ORDERS_API_KEY=7e1VoaeoERRdHQHTS97X8Mpm4DsHI1ru1a0HGpaO

# In-cluster DNS of orders-api (do not use localhost). This is already correct
# for namespace "dev" + chart release "orders-api" on port 8080.
CHECKOUT_BFF_ORDERS_API_URL=http://orders-api.dev.svc.cluster.local:8080


# ── orders-api  → Secret orders-api-secrets (ns dev) ─────────────────────────
# 🔗 MUST EQUAL  CHECKOUT_BFF_ORDERS_API_KEY  above.
ORDERS_API_ORDERS_API_KEY=7e1VoaeoERRdHQHTS97X8Mpm4DsHI1ru1a0HGpaO

# .NET connection string to the CNPG Postgres (cluster "postgres", db "ordersdb",
# owner "orders", rw service postgres-rw). Host/port/db/user are correct as-is.
# 🔗 The Password= here MUST EQUAL  POSTGRES_PASSWORD  below.
ORDERS_API_POSTGRES_CONNECTION_STRING=Host=postgres-rw.dev.svc.cluster.local;Port=5432;Database=ordersdb;Username=orders;Password=8A783DZibevF4rN2wOByqIZ4gpQq


# ── notifier-worker  → Secret notifier-worker-secrets (ns dev) ───────────────
# Bearer token notifier-worker sends with each webhook. Safe random.
NOTIFIER_WORKER_WEBHOOK_AUTH_TOKEN=ohVSJld9sKSEaeOAu7WFZGTlBwFeA5uOMHp6qGGW

# CHANGE ME — where webhooks are POSTed. There is no webhook-sink in the
# cluster; point this at a real receiver (e.g. https://webhook.site/<id> for a
# quick test, or an in-cluster service you deploy).
NOTIFIER_WORKER_WEBHOOK_URL=https://webhook.site/CHANGE-ME


# ── postgres bootstrap  → Secret postgres-bootstrap-credentials (ns dev) ─────
# Used by CNPG to initialise the DB owner. Username must be "orders" (the
# initdb owner in dev-postgres/cluster.yaml).
POSTGRES_USERNAME=orders
# 🔗 MUST EQUAL the Password= inside ORDERS_API_POSTGRES_CONNECTION_STRING above.
POSTGRES_PASSWORD=8A783DZibevF4rN2wOByqIZ4gpQq


# ── redis  → Secret redis-auth (ns dev) ──────────────────────────────────────
# 🔗 MUST EQUAL the password embedded in REDIS_URL below.
REDIS_PASSWORD=UUKn8hmNV7zxBp5GgStHE8kK6CUY


# ── redis url  → Secret redis-url (ns dev) ────────────────────────────────────
# Full connection URL used by checkout-bff / orders-api / notifier-worker.
# Host is the Bitnami standalone master service for release "dev-redis".
# ⚠️ VERIFY the host once after first deploy:
#     kubectl get svc -n dev | grep redis
#   If it differs (e.g. "dev-redis-master"), fix the host here and re-import.
# 🔗 The password segment MUST EQUAL  REDIS_PASSWORD  above.
REDIS_URL=redis://:UUKn8hmNV7zxBp5GgStHE8kK6CUY@dev-redis-redis-master.dev.svc.cluster.local:6379


# ── grafana  → Secret grafana-admin-secret (ns monitoring) ───────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=BOMoc9LHIR6CeZ8dmbo4GLDL


# ── loki s3 backup  → Secret loki-s3-credentials (ns monitoring) ─────────────
# CHANGE ME — these are real AWS IAM keys for the Loki S3 bucket; I can't
# generate valid ones. Paste your actual access key + secret here.
LOKI_S3_AWS_ACCESS_KEY_ID=3LGSTU40JRRNUCQR84JR
LOKI_S3_AWS_SECRET_ACCESS_KEY=3du9Pc8YrtLZU46zIIAaqy5rmBxBWNYXCz9CwdZi
